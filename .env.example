OPENAI_API_KEY=
LLM_PROVIDER=ollama
CHAT_MODEL=gpt-4o-mini
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_BASE_URL=http://127.0.0.1:11434
EMBEDDING_MODEL=text-embedding-3-small
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
RETRIEVAL_BACKEND=local
VECTOR_STORE_PATH=data/vector_store
VECTOR_COLLECTION_NAME=self_healing_rag
LOCAL_INDEX_PATH=data/index/chunks.jsonl
MAX_ATTEMPTS=3
MAX_RETRIEVAL_RETRIES=2
MAX_GENERATION_RETRIES=2
MIN_CONTEXT_SCORE=0.05
MIN_CONTEXT_TERM_OVERLAP=0.15
USE_LLM=false
LLM_FALLBACK_ENABLED=true

# ---------------------------------------------------------------------------
# Reranking (free-tier options)
# ---------------------------------------------------------------------------
# none          = no reranking (default)
# llm           = LLM-based scoring via your configured Ollama/OpenAI model
# cross-encoder = local BAAI/bge-reranker-base via sentence-transformers (free)
#                 install: pip install -e ".[rerank]"
# cohere        = Cohere Rerank API (free trial tier, requires key below)
RERANK_BACKEND=none
RERANK_TOP_K=4
RERANK_CANDIDATES_FACTOR=3
CROSS_ENCODER_MODEL=BAAI/bge-reranker-base

# Cohere free-trial key (only needed when RERANK_BACKEND=cohere)
COHERE_API_KEY=
COHERE_MODEL=rerank-english-v3.0

# ---------------------------------------------------------------------------
# Ragas evaluation (free-tier)
# ---------------------------------------------------------------------------
# When no OPENAI_API_KEY is set, evaluation uses Ollama models locally.
# Install evaluation extras: pip install -e ".[ragas]"
# Run via CLI:  self-healing-rag eval --questions data/demo_questions.json
# Run via API:  POST /evaluate
